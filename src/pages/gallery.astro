---
import BaseLayout from "../layouts/BaseLayout.astro";
import gallery from "../data/gallery.json";
---

<BaseLayout>
  <section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl font-bold mb-6">Gallery</h1>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
      {gallery.map((item) => (
        <figure class="rounded-md overflow-hidden bg-gray-200 dark:bg-gray-800">
          <img src={item.src} alt={item.alt} class="w-full h-full object-cover aspect-square" loading="lazy" />
        </figure>
      ))}
    </div>
  </section>
</BaseLayout>


