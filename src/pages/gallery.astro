---
import BaseLayout from "../layouts/BaseLayout.astro";
import GalleryPage from "../components/GalleryPage";
import gallery from "../data/gallery.json";
---

<BaseLayout>
  <section class="w-full bg-accent-sand/5 dark:bg-[#1d1d1d] text-center flex-1">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-16 pb-24">
      <h1 class="text-3xl font-bold mb-6 text-accent-teal dark:text-white">Gallery</h1>
      <p class="text-sm sm:text-base text-gray-600 dark:text-gray-300 mb-10 max-w-2xl mx-auto">
        A glimpse into the daily scenes and patterns that fuel my sense of style and aesthetic inspiration.
      </p>
      <GalleryPage client:load items={gallery} />
    </div>
  </section>
</BaseLayout>




