---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import GalleryPreview from "../components/GalleryPreview.astro";
import Contact from "../components/Contact.astro";
import ProjectsGrid from "../components/ProjectsGrid";
import SkillsBubbles from "../components/SkillsBubbles";
import projects from "../data/projects.json";
import skills from "../data/skills.json";
---

<BaseLayout>
  <Hero />
  <section id="projects" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-semibold mb-6">Projects</h2>
    <ProjectsGrid client:load projects={projects} />
  </section>
  <section id="skills" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-semibold mb-6">Skills</h2>
    <SkillsBubbles client:load skills={skills} />
  </section>
  <About />
  <GalleryPreview />
  <Contact />
</BaseLayout>


