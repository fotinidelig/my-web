---
import BaseLayout from "../layouts/BaseLayout.astro";
import animations from "../data/animations.json";
---

<BaseLayout>
  <section class="w-full bg-accent-sand/5 dark:bg-[#1d1d1d] flex-1">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-16 pb-24">
      <header class="mb-10 text-center">
        <p class="text-xs sm:text-sm uppercase tracking-[0.3em] text-gray-500 dark:text-gray-400">
          Animated Visualizations
        </p>
        <h1 class="mt-3 text-3xl sm:text-4xl font-bold text-accent-teal dark:text-white">
          Animations from Data
        </h1>
        <p class="mt-4 max-w-2xl mx-auto text-sm sm:text-base text-gray-700 dark:text-gray-300">
          Small, code-driven motion studies built from real data.
        </p>
      </header>

      <!-- Animation card(s) -->
      {
        /* For now we only show the first animation, but the layout supports multiple entries later */
      }
      {animations.slice(0, 1).map((anim) => (
      <article class="mx-auto max-w-5xl rounded-[2.5rem] bg-gradient-to-br from-accent-rose/15 via-accent-sand/40 to-accent-teal/15 dark:from-accent-rose/20 dark:via-gray-900 dark:to-accent-teal/20 shadow-2xl border border-white/40 dark:border-white/10 px-5 py-8 sm:px-8 sm:py-10 lg:px-12 lg:py-12">
        <div class="flex flex-col gap-8 lg:gap-10">
          <header class="space-y-2 text-left">
            <h2 class="text-2xl sm:text-3xl font-semibold text-gray-900 dark:text-gray-50">
              {anim.title}
            </h2>
            <p class="text-sm sm:text-base text-gray-700 dark:text-gray-300 max-w-2xl">
              {anim.description}
            </p>
          </header>

          <!-- Animation + annotations -->
          <div class="relative mx-auto w-full max-w-4xl aspect-[16/9]">
            <!-- Animation fills most of the frame without additional colored shapes -->
            <div class="absolute inset-0 flex items-center justify-center">
              <button
                type="button"
                class="h-full w-full max-h-full max-w-full flex items-center justify-center cursor-pointer"
                data-lightbox-src={anim.gifSrc}
                data-lightbox-alt={anim.title}
              >
                <img
                  src={anim.gifSrc}
                  alt={anim.title}
                  class="h-full w-full max-h-full max-w-full object-contain"
                  loading="eager"
                />
              </button>
            </div>
          </div>

          <!-- Description + original static viz -->
          <div class="mt-4 grid gap-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)] items-start">
            <section class="space-y-4">
              <h3 class="text-sm font-semibold uppercase tracking-[0.22em] text-gray-500 dark:text-gray-400">
                About this animation
              </h3>
              {anim.about?.map((paragraph) => (
                <p class="text-sm sm:text-base text-gray-700 dark:text-gray-300">
                  {paragraph}
                </p>
              ))}
            </section>

            <section class="space-y-3">
              <h3 class="text-sm font-semibold uppercase tracking-[0.22em] text-gray-500 dark:text-gray-400">
                Original static visualization
              </h3>
              <div>
                <button
                  type="button"
                  class="w-full cursor-pointer"
                  data-lightbox-src={anim.staticSrc}
                  data-lightbox-alt={`Static visualization that inspired ${anim.title}`}
                >
                  <img
                    src={anim.staticSrc}
                    alt={`Static visualization that inspired ${anim.title}`}
                    class="w-full rounded-2xl object-contain shadow-xl"
                    loading="lazy"
                  />
                </button>
              </div>
            </section>
          </div>

          {anim.repo && (
            <div class="mt-4 flex justify-end">
              <a
                href={anim.repo}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-1.5 rounded-full bg-white/60 px-2.5 py-1 text-[0.7rem] font-medium text-gray-800 shadow-sm transition-colors hover:border-gray-400 hover:bg-white/90 dark:border-gray-700/70 dark:bg-gray-900/70 dark:text-gray-100 dark:hover:border-gray-500 dark:hover:bg-gray-900"
                aria-label={`Open ${anim.title} on GitHub`}
              >
                <svg
                  class="h-3 w-3"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M12 .5C5.648.5.5 5.648.5 12.004c0 5.094 3.292 9.41 7.864 10.94.575.106.787-.25.787-.558 0-.276-.01-1.17-.016-2.123-3.2.696-3.876-1.373-3.876-1.373-.523-1.327-1.278-1.68-1.278-1.68-1.044-.714.079-.7.079-.7 1.154.081 1.761 1.185 1.761 1.185 1.027 1.76 2.695 1.252 3.35.958.104-.744.402-1.252.73-1.54-2.553-.29-5.236-1.278-5.236-5.69 0-1.257.449-2.287 1.184-3.093-.119-.29-.513-1.457.113-3.04 0 0 .967-.31 3.17 1.182a11.06 11.06 0 0 1 2.886-.388c.979.004 1.967.132 2.888.388 2.2-1.492 3.165-1.182 3.165-1.182.629 1.583.235 2.75.116 3.04.738.806 1.183 1.836 1.183 3.093 0 4.425-2.688 5.395-5.252 5.68.413.357.78 1.057.78 2.132 0 1.54-.014 2.78-.014 3.16 0 .311.207.67.793.556C20.213 21.41 23.5 17.096 23.5 12.004 23.5 5.648 18.352.5 12 .5Z" />
                </svg>
                <span>View code</span>
              </a>
            </div>
          )}
        </div>
      </article>
      ))}

      <!-- Placeholder for future animations -->
      <div class="mt-12 border-t border-dashed border-gray-300/70 dark:border-gray-700/70 pt-8 text-center text-xs sm:text-sm text-gray-500 dark:text-gray-400">
        More animation studies coming soon — each tied to a specific project and dataset.
      </div>
    </div>
  </section>

  <!-- Simple lightbox for viewing animations and images in close up -->
  <div
    id="animation-lightbox"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 p-4 md:p-8"
    aria-modal="true"
    role="dialog"
  >
    <button
      type="button"
      id="animation-lightbox-close"
      class="absolute top-4 right-4 rounded-full bg-white/80 px-3 py-1 text-xs font-medium text-gray-900 shadow-md hover:bg-white"
      aria-label="Close full-size view"
    >
      Close
    </button>
    <img
      id="animation-lightbox-image"
      src=""
      alt=""
      class="max-h-[90vh] max-w-[90vw] rounded-2xl shadow-2xl object-contain"
    />
  </div>

  <script>
    (function () {
      const overlay = document.getElementById('animation-lightbox');
      const img = document.getElementById('animation-lightbox-image');
      const closeBtn = document.getElementById('animation-lightbox-close');

      if (!overlay || !img || !closeBtn) return;

      const openLightbox = (src, alt) => {
        img.src = src;
        img.alt = alt || '';
        overlay.classList.remove('hidden');
        overlay.classList.add('flex');
        document.body.style.overflow = 'hidden';
      };

      const closeLightbox = () => {
        overlay.classList.add('hidden');
        overlay.classList.remove('flex');
        img.src = '';
        document.body.style.overflow = '';
      };

      document.querySelectorAll('[data-lightbox-src]').forEach((el) => {
        el.addEventListener('click', (event) => {
          event.preventDefault();
          const target = event.currentTarget;
          const src = target.getAttribute('data-lightbox-src');
          const alt = target.getAttribute('data-lightbox-alt') || '';
          if (src) openLightbox(src, alt);
        });
      });

      closeBtn.addEventListener('click', closeLightbox);
      overlay.addEventListener('click', (event) => {
        if (event.target === overlay) {
          closeLightbox();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeLightbox();
        }
      });
    })();
  </script>
</BaseLayout>

