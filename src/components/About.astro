---
import Timeline from "./Timeline";
import timeline from "../data/timeline.json";
---

<section id="about" class="w-full bg-accent-sand/5 text-center">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-16 pb-24">
    <h2 class="text-3xl font-semibold mb-6 text-accent-teal dark:text-white">About Me</h2>
    <p class="mx-auto mb-10 max-w-3xl text-body text-gray-700 dark:text-gray-200">
      My journey spans computer science, engineering, and research, with a focus on artificial intelligence and data. Beyond technical work, I explore aesthetic expression through photography and design—glimpses of which you can see in my <a href="/gallery" class="underline decoration-secondary/60 underline-offset-[5px] transition-colors hover:text-secondary dark:hover:text-secondary">photo gallery</a>.
    </p>
    <Timeline client:load items={timeline} />
  </div>
</section>




