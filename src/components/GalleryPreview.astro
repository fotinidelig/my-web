---
import gallery from "../data/gallery.json";
---

<section id="gallery" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-16 text-center">
  <div class="mb-6">
    <h2 class="text-3xl font-semibold text-accent-teal dark:text-white">Gallery</h2>
    <a href="/gallery" class="mt-2 inline-block text-sm underline text-gray-800 dark:text-gray-100 hover:text-accent-teal">View all</a>
  </div>
  <div class="mx-auto max-w-6xl grid gap-3 justify-center justify-items-center grid-cols-[repeat(auto-fit,minmax(160px,1fr))]">
    {gallery.slice(0, 8).map((item) => (
      <a href="/gallery" class="aspect-square rounded-md overflow-hidden bg-gray-200 dark:bg-gray-800">
        <img src={item.src} alt={item.alt} class="w-full h-full object-cover" loading="lazy" />
      </a>
    ))}
  </div>
</section>




