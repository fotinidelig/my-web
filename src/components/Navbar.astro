---
import ThemeToggle from "./ThemeToggle";

const NAV_ITEMS = [
  { href: "/#about", label: "About" },
  { href: "/#projects", label: "Projects" },
  { href: "/#skills", label: "Skills" },
  { href: "/#gallery", label: "Gallery" },
  { href: "/#contact", label: "Contact" },
];
---

<header class="fixed inset-x-0 top-0 z-50  bg-white/60 backdrop-blur navbar-gradient dark:bg-black/30">
  <nav class="mx-auto flex h-16 w-full max-w-7xl items-center px-4 sm:px-6 lg:px-10">
    <a
      href="/#hero"
      class="font-neonderthaw text-3xl leading-none text-gray-900 transition-colors duration-300 dark:text-gray-100 sm:text-4xl md:text-5xl"
      style="font-family: 'Neonderthaw', cursive;"
    >
      fotini.d
    </a>

    <div class="ml-auto flex items-center gap-2 md:hidden">
      <ThemeToggle client:load className="md:hidden" />
      <details class="relative">
        <summary
          class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-gray-200/70 bg-white/80 text-gray-700 shadow-sm transition hover:border-secondary/60 hover:text-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:border-gray-700/60 dark:bg-gray-900/80 dark:text-gray-200 dark:hover:border-secondary/50 dark:hover:text-secondary"
        >
          <span class="sr-only">Open navigation menu</span>
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4 6.75A.75.75 0 014.75 6h14.5a.75.75 0 010 1.5H4.75A.75.75 0 014 6.75zm0 10.5a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H4.75a.75.75 0 01-.75-.75zm0-5.25a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H4.75a.75.75 0 01-.75-.75z" />
          </svg>
        </summary>
        <div class="absolute right-0 mt-3 w-48 rounded-2xl border border-gray-200/70 bg-white/90 p-3 shadow-xl backdrop-blur dark:border-gray-700/70 dark:bg-gray-900/95">
          <ul class="flex flex-col gap-2">
            {NAV_ITEMS.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="block rounded-xl px-4 py-2 text-sm font-medium text-gray-800 transition-colors duration-200 hover:bg-secondary/10 hover:text-secondary focus:outline-none focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2 dark:text-gray-100 dark:hover:bg-secondary/15 dark:hover:text-secondary"
                  onclick="this.closest('details').removeAttribute('open')"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </details>
    </div>

    <ul class="ml-auto hidden items-center gap-8 text-lg md:flex">
      {NAV_ITEMS.map((item) => (
        <li>
          <a href={item.href} class="text-gray-800 transition-colors duration-200 hover:text-secondary dark:text-gray-100 dark:hover:text-secondary">
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <ThemeToggle client:load className="hidden md:inline-flex ml-4" />
  </nav>
</header>


